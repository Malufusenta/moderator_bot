# ─── Telegram Bot ────────────────────────────────────────────────────────────
BOT_TOKEN=

# ─── Pyrogram (для parser.py) ─────────────────────────────────────────────────
API_ID=
API_HASH=

# ─── Чат и права ─────────────────────────────────────────────────────────────
# ID группового чата (отрицательное число, например -1001234567890)
CHAT_ID=
# Список ID администраторов через запятую (доступ к досье в ЛС)
# Пример: ADMIN_IDS=123456789,987654321
ADMIN_IDS=

# Список ID, для которых проверки объявлений отключены
# Пример: WHITELIST_IDS=111111111,222222222
WHITELIST_IDS=3

# ─── Пороги модерации (раздел 3 ТЗ) ──────────────────────────────────────────
# Порог суммарных сообщений за всё время для признания «доверенным»
TRUST_LIMIT=30

# Окно «свежести» активности (в днях)
RECENCY_DAYS=60

# Минимум сообщений в окне свежести (без учёта текущего)
RECENCY_MIN_MESSAGES=1

# Порог схожести для анти-дубля (0.0–1.0)
SIMILARITY_THRESHOLD=0.85

# ─── Ответные меры ────────────────────────────────────────────────────────────
# Длительность мута в часах
MUTE_HOURS=24

# Через сколько секунд удалять предупреждение бота в чате
WARNING_DELETE_SECONDS=15

# ─── Лог модераторских действий ──────────────────────────────────────────────
# ID чата или канала, куда бот пишет о каждом муте/нарушении.
# Бот должен быть участником (или администратором) этого чата.
# 0 = функция отключена
LOG_CHAT_ID=0

# ─── БД ───────────────────────────────────────────────────────────────────────
DB_PATH=data/bot.db

DRY_RUN=False